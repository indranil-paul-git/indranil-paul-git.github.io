---
import RootLayout from '../layouts/RootLayout.astro';
import { getSiteConfig } from '../lib/navigation';

const config = getSiteConfig();
---

<RootLayout title="404: Not Found" currentPath="/404">
  <div class="error-hero">
    <div class="error-centered">
      <div class="error-code">
        <span class="error-prompt">error:</span>
        <span class="error-main">404</span>
      </div>
      <h1 class="error-title">Page Not Found</h1>
      <p class="error-desc">
        The requested path could not be resolved. It may have been moved, deleted, or does not exist.
      </p>
      
      <div class="action-wrapper">
        <a href="/" class="home-button">
          Return to Terminal
        </a>
      </div>
    </div>
  </div>
</RootLayout>

<style>
  .error-hero {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    box-sizing: border-box;
    overflow: hidden;
  }

  .error-centered {
    position: absolute;
    top: 48%; /* Optical vertical center adjustment */
    left: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    user-select: none;
    text-align: center;
    padding: 0 2rem;
    width: 100%;
    box-sizing: border-box;
  }

  .error-code {
    position: relative;
    font-family: var(--font-heading);
    font-size: 8rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1;
    display: inline-flex;
    justify-content: center;
    white-space: nowrap;
    align-items: baseline;
  }

  .error-prompt {
    font-family: var(--font-mono);
    font-weight: 950;
    font-size: 3.5rem;
    background: linear-gradient(135deg, #0047ab 0%, #ff4500 50%, var(--sunset-magenta) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    filter: drop-shadow(0 0 15px rgba(255, 126, 71, 0.35));
    opacity: 0.6;
    margin-right: 0.8rem;
  }

  .error-main {
    color: rgba(255, 250, 240, 0.7);
    text-shadow: 0 0 15px rgba(255, 126, 71, 0.35), 
                 0 0 35px rgba(255, 165, 0, 0.18);
  }

  .error-title {
    color: rgba(255, 250, 240, 0.9);
    font-size: 2.2rem;
    font-weight: 600;
    margin: 1.5rem 0 0.5rem 0;
    font-family: var(--font-heading);
    border-bottom: none;
    padding: 0;
    text-shadow: 0 0 10px rgba(255, 126, 71, 0.25);
  }

  .error-desc {
    color: var(--text-secondary);
    font-size: 1.1rem;
    max-width: 480px;
    margin-bottom: 2.5rem;
    line-height: 1.6;
    text-align: center;
  }

  .action-wrapper {
    z-index: 10;
  }

  .home-button {
    display: inline-block;
    padding: 1.1rem 2.2rem;
    border-radius: 9999px;
    background: rgba(10, 15, 20, 0.15);
    border: 1px solid var(--glass-border);
    backdrop-filter: blur(28px);
    -webkit-backdrop-filter: blur(28px);
    box-shadow: var(--glass-shadow);
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 0.95rem;
    text-decoration: none;
    transition: border-color var(--transition-fast), background var(--transition-fast), box-shadow var(--transition-fast), transform var(--transition-fast);
  }

  .home-button:hover {
    background: rgba(10, 15, 20, 0.3);
    border-color: var(--sunset-orange);
    color: var(--text-primary);
    box-shadow: 0 0 25px rgba(255, 126, 71, 0.15);
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .error-code {
      font-size: 6rem;
    }
    .error-prompt {
      font-size: 2.5rem;
    }
    .error-title {
      font-size: 1.8rem;
    }
    .error-desc {
      font-size: 1rem;
    }
  }
</style>
