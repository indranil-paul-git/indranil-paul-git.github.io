<script>
  // Canvas Graph Physics animation
  const canvas = document.getElementById('bg-network-graph') as HTMLCanvasElement | null;
  if (canvas) {
    const ctx = canvas.getContext('2d');
    if (ctx) {
      let width = 0;
      let height = 0;
      let animationFrameId: number;
      let nodes: { x: number; y: number; vx: number; vy: number; radius: number }[] = [];
      
      const NODE_COUNT = 45;
      const MAX_DIST = 130;
      const SPEED_SCALE = 0.18; // Very slow, calm drifting motion

      // Fetch network design tokens dynamically from CSS custom properties
      const styles = window.getComputedStyle(document.documentElement);
      const networkNodeColor = styles.getPropertyValue('--network-node-color').trim() || 'rgba(217, 93, 57, 0.5)';
      const networkLineColorRaw = styles.getPropertyValue('--network-line-color').trim() || '232, 122, 49';

      const resize = () => {
        width = canvas.width = window.innerWidth;
        height = canvas.height = window.innerHeight;
      };

      const initNodes = () => {
        nodes = [];
        for (let i = 0; i < NODE_COUNT; i++) {
          nodes.push({
            x: Math.random() * width,
            y: Math.random() * height,
            vx: (Math.random() * 2 - 1) * SPEED_SCALE,
            vy: (Math.random() * 2 - 1) * SPEED_SCALE,
            radius: Math.random() * 1.5 + 1
          });
        }
      };

      const draw = () => {
        if (!ctx) return;
        ctx.clearRect(0, 0, width, height);

        // Draw connections
        for (let i = 0; i < nodes.length; i++) {
          const n1 = nodes[i];
          for (let j = i + 1; j < nodes.length; j++) {
            const n2 = nodes[j];
            const dx = n1.x - n2.x;
            const dy = n1.y - n2.y;
            const dist = Math.sqrt(dx * dx + dy * dy);

            if (dist < MAX_DIST) {
              const alpha = (1 - dist / MAX_DIST) * 0.95;
              ctx.strokeStyle = `rgba(${networkLineColorRaw}, ${alpha * 0.14})`; // Sunset Gold connection
              ctx.lineWidth = 0.8;
              ctx.beginPath();
              ctx.moveTo(n1.x, n1.y);
              ctx.lineTo(n2.x, n2.y);
              ctx.stroke();
            }
          }
        }

        // Draw and update nodes
        nodes.forEach(node => {
          ctx.fillStyle = networkNodeColor; // Sunset Coral nodes
          ctx.beginPath();
          ctx.arc(node.x, node.y, node.radius, 0, Math.PI * 2);
          ctx.fill();

          // Move
          node.x += node.vx;
          node.y += node.vy;

          // Wall bouncing
          if (node.x < 0 || node.x > width) node.vx = -node.vx;
          if (node.y < 0 || node.y > height) node.vy = -node.vy;
        });
      };

      const loop = () => {
        draw();
        animationFrameId = requestAnimationFrame(loop);
      };

      // Set up resize handler and initialize
      resize();
      initNodes();
      loop();

      window.addEventListener('resize', () => {
        resize();
        initNodes();
      });

      // Pause loop when page is hidden to conserve system resources
      document.addEventListener('visibilitychange', () => {
        if (document.hidden) {
          cancelAnimationFrame(animationFrameId);
        } else {
          loop();
        }
      });
    }
  }

  // --- Parallax scroll effect (normalized to scroll percentage) ---
  {
    const scrollContainer = document.querySelector('.app-scroll-container') as HTMLElement | null;
    const bokehStars = document.getElementById('bokeh-stars') as HTMLElement | null;
    const sunEl = document.querySelector('.sunset-sun') as HTMLElement | null;
    
    // Select both buildings and lights layers for parallax displacement
    const skylineFarLayers = document.querySelectorAll('.skyline-far-buildings, .skyline-far-lights');
    const skylineMidLayers = document.querySelectorAll('.skyline-mid-buildings, .skyline-mid-lights');
    const skylineNearLayers = document.querySelectorAll('.skyline-near-buildings, .skyline-near-lights');

    // Fixed max displacement in pixels — independent of page length.
    // scrollPercent (0→1) * MAX = consistent displacement on any page.
    const MAX_STARS  = 10;
    const MAX_SUN    = 20;
    const MAX_FAR    = 35;
    const MAX_MID    = 55;
    const MAX_NEAR   = 80;

    if (scrollContainer) {
      let ticking = false;

      const applyParallax = () => {
        const maxScroll = scrollContainer.scrollHeight - scrollContainer.clientHeight;
        const pct = maxScroll > 0 ? scrollContainer.scrollTop / maxScroll : 0;

        if (bokehStars) {
          bokehStars.style.transform = `translate3d(0, ${pct * -MAX_STARS}px, 0)`;
        }
        if (sunEl) {
          sunEl.style.transform = `translate3d(-50%, ${pct * -MAX_SUN}px, 0)`;
        }
        skylineFarLayers.forEach(el => {
          (el as HTMLElement).style.transform = `translate3d(0, ${pct * -MAX_FAR}px, 0)`;
        });
        skylineMidLayers.forEach(el => {
          (el as HTMLElement).style.transform = `translate3d(0, ${pct * -MAX_MID}px, 0)`;
        });
        skylineNearLayers.forEach(el => {
          (el as HTMLElement).style.transform = `translate3d(0, ${pct * -MAX_NEAR}px, 0)`;
        });

        ticking = false;
      };

      scrollContainer.addEventListener('scroll', () => {
        if (!ticking) {
          ticking = true;
          requestAnimationFrame(applyParallax);
        }
      }, { passive: true });
    }
  }
</script>
