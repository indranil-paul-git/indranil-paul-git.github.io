---
// Build-time random generation of bokeh stars to avoid client-side script dependency
const stars = Array.from({ length: 32 }, (_, i) => ({
  size: Math.random() * 3 + 3, // 3px to 6px (smaller, delicate stars)
  x: Math.random() * 100,
  y: Math.random() * 75, // focus stars in the upper 75% of the sky
  duration: Math.random() * 10 + 8, // 8s to 18s cycle
  delay: Math.random() * -18, // Pre-warm phase
  blur: Math.random() * 0.7 + 0.6, // 0.6px to 1.3px blur for soft dreamy edges
}));
---
<!-- Ambient background wrapper -->
<div class="bg-effects-layer" aria-hidden="true">

  <!-- Glowing Bokeh Stars -->
  <div class="bokeh-stars-container" id="bokeh-stars">
    {stars.map((star) => (
      <div
        class="bokeh-star"
        style={`width: ${star.size}px; height: ${star.size}px; left: ${star.x}%; top: ${star.y}%; animation-duration: ${star.duration}s; animation-delay: ${star.delay}s; filter: blur(${star.blur}px);`}
      />
    ))}
  </div>
  
  <!-- Glowing sunset sun -->
  <div class="sunset-sun"></div>
  

  <!-- Subtle networking animation canvas -->
  <canvas id="bg-network-graph" class="bg-graph-canvas"></canvas>
  
