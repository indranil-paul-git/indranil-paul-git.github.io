---
import '../styles/global.css';
import BackgroundEffects from '../components/BackgroundEffects.astro';
import Sidebar from '../components/Sidebar.astro';
import Search from '../components/Search.astro';
import TableOfContents from '../components/TableOfContents.astro';
import { Menu, Search as SearchIcon } from '@lucide/astro';
import { getSiteConfig } from '../lib/navigation';

interface Props {
  title: string;
  description?: string;
  headings?: { depth: number; slug: string; text: string }[];
  currentPath?: string;
}

const { title, description = "Personal Knowledge Portal & Portfolio", headings = [], currentPath = '/' } = Astro.props;

const config = getSiteConfig();

const tabTitle = currentPath === '/' ? config.titleSuffix : `${title} • ${config.titleSuffix}`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{tabTitle}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <meta name="generator" content={Astro.generator} />

    <!-- Google Fonts: Jost (headings) + JetBrains Mono (body/mono) + Space Mono (code) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Jost:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
    
    <!-- Flicker-free layout state restoration -->
    <script is:inline>
      // 1. Minimized sidebar check (inject dynamically before DOM paint)
      const sidebarMinimized = localStorage.getItem('sidebar-minimized') !== 'false';
      if (sidebarMinimized) {
        document.documentElement.classList.add('sidebar-minimized');
      }

      // 2. Folder toggle state check
      try {
        const states = JSON.parse(localStorage.getItem('sidebar-folder-states') || '{}');
        const styles = [
          '.no-transition *, .no-transition::after, .no-transition::before { transition: none !important; }'
        ];
        
        // Block all layout transitions during load / hydration
        document.documentElement.classList.add('no-transition');

        for (const [folderId, expanded] of Object.entries(states)) {
          if (expanded === false) {
            styles.push(`.folder-item[data-folder-id="${folderId}"] .folder-children-container { grid-template-rows: 0fr !important; }`);
            styles.push(`.folder-item[data-folder-id="${folderId}"] .folder-toggle-icon { transform: rotate(-90deg) !important; }`);
          } else if (expanded === true) {
            styles.push(`.folder-item[data-folder-id="${folderId}"] .folder-children-container { grid-template-rows: 1fr !important; }`);
            styles.push(`.folder-item[data-folder-id="${folderId}"] .folder-toggle-icon { transform: rotate(0deg) !important; }`);
          }
        }
        
        const styleEl = document.createElement('style');
        styleEl.id = 'sidebar-temp-styles';
        styleEl.innerHTML = styles.join('\n');
        document.head.appendChild(styleEl);
      } catch (e) {
        console.error(e);
      }
    </script>

    <!-- Critical layout styles to prevent FOUC / layout shift in dev mode -->
    <style is:inline>
      :root {
        --sidebar-width: 330px;
        --header-height: 60px;
        --toc-width: 240px;
        --max-content-width: 1000px;
      }
      
      .app-container {
        display: flex;
        flex-direction: column;
        height: 100vh;
        width: 100vw;
        position: relative;
        overflow: hidden;
      }
      
      .app-body {
        display: flex;
        flex-direction: row;
        flex: 1 1 0%;
        min-height: 0;
        width: 100vw;
        position: relative;
        overflow: hidden;
      }
      
      .app-sidebar {
        width: var(--sidebar-width);
        height: 100%;
        flex-shrink: 0;
        position: relative;
        z-index: 100;
      }
      
      .header-brand-wrapper {
        min-width: 330px;
        width: max-content;
        height: 100%;
        display: flex;
        align-items: center;
        padding: 0 1.25rem;
        flex-shrink: 0;
        pointer-events: auto;
      }
      
      .header-main-wrapper {
        flex: 1 1 0%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 2.5rem;
        pointer-events: auto;
      }
      
      .app-main {
        flex: 1 1 0%;
        min-width: 0;
        display: flex;
        flex-direction: column;
        height: 100%;
        overflow: hidden;
      }
      
      .app-scroll-container {
        flex-grow: 1;
        overflow-y: auto;
        padding: 2.5rem 2.5rem 0 2.5rem;
      }
      
      .is-home .app-scroll-container {
        display: flex;
        flex-direction: column;
        height: 100%;
        padding: 0;
        overflow: hidden;
      }

      .is-home .content-wrapper {
        display: flex;
        flex-direction: column;
        flex-grow: 1;
        height: 100%;
        max-width: 100%;
      }

      .is-home .content-body {
        display: flex;
        flex-direction: column;
        flex-grow: 1;
        height: 100%;
        width: 100%;
        max-width: 100%;
      }
      
      .content-wrapper {
        width: 100%;
        max-width: 700px;
        margin: 0 auto;
        display: flex;
        position: relative;
        justify-content: center;
        transition: transform var(--transition-normal), max-width var(--transition-normal);
      }
      
      .content-body {
        width: 100%;
      }

      .sidebar-minimized .content-wrapper {
        max-width: 820px;
      }

      @media (min-width: 1360px) {
        .content-wrapper {
          transform: translateX(calc(-1 * var(--sidebar-width) / 2));
        }
      }

      .toc-container-wrapper {
        position: absolute;
        top: 0;
        bottom: 0;
        left: calc(100% + 3rem);
        width: var(--toc-width);
        pointer-events: none;
      }

      .app-toc {
        width: var(--toc-width);
        pointer-events: auto;
      }
      
      @media (max-width: 768px) {
        :root {
          --sidebar-width: 0px;
        }
        .app-sidebar {
          position: fixed;
          top: 0;
          left: 0;
          height: 100%;
          width: 280px;
          transform: translateX(-100%);
        }
        .header-brand-wrapper {
          width: auto;
          border-right: none;
          padding: 0 1rem;
        }
        .header-main-wrapper {
          padding: 0 1rem;
        }
      }

      /* Table of Contents responsiveness */
      @media (max-width: 1300px) {
        html:not(.sidebar-minimized) .toc-container-wrapper {
          display: none !important;
        }
        html:not(.sidebar-minimized) :root {
          --toc-width: 0px;
        }
      }

      @media (max-width: 1400px) {
        html.sidebar-minimized .toc-container-wrapper {
          display: none !important;
        }
        html.sidebar-minimized :root {
          --toc-width: 0px;
        }
      }

      .folder-header-icon {
        display: inline-flex !important;
        align-items: center !important;
        justify-content: center !important;
        color: var(--accent-purple) !important;
        flex-shrink: 0 !important;
        width: 32px !important;
        height: 32px !important;
        position: relative !important;
        top: -2px !important;
      }
      .folder-header-icon svg {
        display: block !important;
        width: 32px !important;
        height: 32px !important;
      }
    </style>
  </head>
  <body>
    <!-- Ambient Visual Effects -->
    <BackgroundEffects />

    <div class={`app-container ${currentPath === '/' ? 'is-home' : ''}`}>
      {currentPath !== '/' && (
        <header class="app-header">
          <div class="header-brand-wrapper">
            <!-- Mobile Menu Toggle Button -->
            <button class="mobile-menu-btn" aria-label="Toggle sidebar" id="mobile-sidebar-toggle" style="display: none; padding: 0.25rem; margin-right: 0.5rem; align-items: center; justify-content: center;">
              <Menu size={20} />
            </button>
            
            <!-- Logo inside the header -->
            <a href={import.meta.env.BASE_URL} class="logo">
              <span class="logo-prompt">{config.logoPrompt}</span>
              <span class="logo-main">{config.logoMain}</span>
              <span class="logo-divider">/</span>
              <span class="logo-secondary">{config.logoSecondary}</span>
            </a>
          </div>

          <div class="header-main-wrapper">
            <div class="header-title-wrapper">
              <span class="header-title-main">{title}</span>
            </div>

            <!-- Header Search Button -->
            <button
              id="header-search-btn"
              class="header-search-btn search-trigger-btn"
              title="Search portal (Ctrl+K)"
            >
              <SearchIcon size={14} class="search-btn-icon" />
              <span class="search-btn-text">Search...</span>
              <kbd class="search-btn-kbd">Ctrl+K</kbd>
            </button>
          </div>
        </header>
      )}

      <div class="app-body">
        <!-- Collapsible Left Sidebar -->
        <Sidebar currentPath={currentPath} />

        <!-- Main Portal Window -->
        <main class="app-main">
          <!-- Scrolling content panel -->
          <div class="app-scroll-container">
            <div class="content-wrapper">
              <!-- Article Body -->
              <article class="content-body markdown-content">
                <slot />
              </article>

              <!-- Table of Contents (Heading Spy) -->
              {headings.length > 0 && (
                <div class="toc-container-wrapper">
                  <TableOfContents headings={headings} />
                </div>
              )}
            </div>
          </div>
        </main>
      </div>
    </div>

    <!-- Command Palette Search Interface -->
    <Search />

    <!-- Global Custom Site Tooltip -->
    <div id="custom-site-tooltip" class="custom-site-tooltip"></div>

    <!-- Core Interactive Client Scripts -->
    <script>
      // 1. Mobile sidebar toggler
      const mobileToggleBtn = document.getElementById('mobile-sidebar-toggle');
      if (mobileToggleBtn) {
        mobileToggleBtn.addEventListener('click', () => {
          document.body.classList.toggle('sidebar-open');
        });
      }

      // 2. Hide mobile sidebar when clicking on main panel
      const mainPanel = document.querySelector('.app-main');
      if (mainPanel) {
        mainPanel.addEventListener('click', () => {
          if (document.body.classList.contains('sidebar-open')) {
            document.body.classList.remove('sidebar-open');
          }
        });
      }

      // Responsive sidebar buttons styling
      const adjustMobileButtons = () => {
        const toggleBtn = document.getElementById('mobile-sidebar-toggle');
        if (toggleBtn) {
          if (window.innerWidth <= 768) {
            toggleBtn.style.display = 'flex';
          } else {
            toggleBtn.style.display = 'none';
          }
        }
      };
      window.addEventListener('resize', adjustMobileButtons);
      adjustMobileButtons();

      // 4. Header title scroll-reveal: show page heading in header only when main content title has scrolled behind it
      const scrollContainer = document.querySelector('.app-scroll-container');
      const headerTitle = document.querySelector('.header-title-wrapper');
      
      if (scrollContainer && headerTitle) {
        const checkHeadingVisibility = () => {
          const h1 = scrollContainer.querySelector('h1');
          if (!h1) {
            headerTitle.classList.add('visible');
            return;
          }
          
          const rect = h1.getBoundingClientRect();
          // The top screen header is 60px tall. Once the bottom of the content h1 has scrolled above 60px, it is hidden behind the header.
          if (rect.bottom < 60) {
            headerTitle.classList.add('visible');
          } else {
            headerTitle.classList.remove('visible');
          }
        };
        
        scrollContainer.addEventListener('scroll', checkHeadingVisibility, { passive: true });
        checkHeadingVisibility();
      }

      // 3. Code copy-to-clipboard activation
      document.querySelectorAll('pre').forEach((pre) => {
        if (pre.classList.contains('mermaid')) return;

        // Wrap pre in code-block-wrapper
        const wrapper = document.createElement('div');
        wrapper.className = 'code-block-wrapper';
        pre.parentNode?.insertBefore(wrapper, pre);
        wrapper.appendChild(pre);

        // Copy button markup
        const button = document.createElement('button');
        button.className = 'copy-code-button';
        button.setAttribute('aria-label', 'Copy code to clipboard');
        button.innerHTML = `
          <svg class="copy-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
          <svg class="check-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
        `;
        wrapper.appendChild(button);

        button.addEventListener('click', async () => {
          const codeEl = pre.querySelector('code');
          const text = codeEl ? codeEl.innerText : pre.innerText;

          try {
            await navigator.clipboard.writeText(text);
            button.classList.add('copied');
            setTimeout(() => button.classList.remove('copied'), 2000);
          } catch (err) {
            console.error('Failed to copy text: ', err);
          }
        });
      });

      // 5. Global Custom Tooltip handling
      const tooltip = document.getElementById('custom-site-tooltip');
      if (tooltip) {
        let activeTarget: HTMLElement | null = null;

        const hideTooltip = () => {
          tooltip.classList.remove('visible');
          activeTarget = null;
        };

        document.addEventListener('mouseover', (e) => {
          const target = (e.target as HTMLElement).closest('[data-tooltip]') as HTMLElement | null;
          if (target && target !== activeTarget) {
            activeTarget = target;
            const text = target.getAttribute('data-tooltip');
            if (text) {
              tooltip.textContent = text;
              tooltip.classList.add('visible');
              
              const rect = target.getBoundingClientRect();
              const x = rect.left + rect.width / 2;
              const y = rect.top - 8; // 8px spacing above element
              tooltip.style.left = `${x}px`;
              tooltip.style.top = `${y}px`;
            }
          }
        });

        document.addEventListener('mouseout', (e) => {
          const target = (e.target as HTMLElement).closest('[data-tooltip]') as HTMLElement | null;
          if (target && target === activeTarget) {
            const related = e.relatedTarget as HTMLElement | null;
            if (!related || !target.contains(related)) {
              hideTooltip();
            }
          }
        });

        window.addEventListener('scroll', hideTooltip, { passive: true });
      }
    </script>
  </body>
</html>
